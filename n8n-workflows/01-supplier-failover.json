        [{ "node": "下單成功？", "type": "main", "index": 0 }]
      ]
    },
    "下單成功？": {
      "main": [
        [{ "node": "更新訂單狀態（成功）", "type": "main", "index": 0 }],
        [{ "node": "故障轉移（下一供應商）", "type": "main", "index": 0 }]
      ]
    },
    "故障轉移（下一供應商）": {
      "main": [
        [{ "node": "還有備選供應商？", "type": "main", "index": 0 }]
      ]
    },
    "還有備選供應商？": {
      "main": [
        [{ "node": "取得供應商路由", "type": "main", "index": 0 }],
        [{ "node": "通知管理員（全部失敗）", "type": "main", "index": 0 }, { "node": "更新訂單狀態（失敗）", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
